# ============================================================
# VentaFácil — .gitignore
# ============================================================

# --- Secrets / Environment ---
.env
.env.local
.env.*.local
*.env

# --- Python / Backend ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/
*.egg-info/
dist/
build/
.eggs/
*.egg
*.whl
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
coverage.xml
*.log

# --- Alembic auto-generated (keep versions, ignore cache) ---
alembic/__pycache__/

# --- Flutter / Dart ---
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.g.dart
*.freezed.dart
*.mocks.dart

# Android
frontend/android/.gradle/
frontend/android/local.properties
frontend/android/key.properties
frontend/android/app/google-services.json
frontend/android/app/*.keystore

# iOS
frontend/ios/Pods/
frontend/ios/.symlinks/
frontend/ios/Flutter/Flutter.framework
frontend/ios/Flutter/Flutter.podspec
frontend/ios/Runner.xcworkspace/

# --- Node / React prototype ---
node_modules/
.next/
out/
dist/
.cache/
.wrangler/

# --- Local agent/runtime artifacts ---
.kilo/
images/
logs/*
!logs/.gitkeep
!logs/README.md
graphify-out/.graphify_python
graphify-out/cache/
graphify-out/cost.json

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/settings.json
.idea/
*.swp
*.swo
