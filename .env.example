# ============================================================
# VentaFácil — .env.example
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- PostgreSQL ---
# Local Docker:
# DATABASE_URL=postgresql+psycopg://ventafacil_user:123@127.0.0.1:5433/ventafacil_dev
#
# Neon:
# Use the pooled host (-pooler) in DATABASE_URL for the app.
# Use the direct host in DIRECT_DATABASE_URL for Alembic migrations when available.
# If Neon gives a postgresql:// URL, change it to postgresql+psycopg:// for this backend.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/ventafacil_dev
DIRECT_DATABASE_URL=
DB_ECHO=false
SEED_DEMO_DATA=true

# --- Redis (optional) ---
REDIS_URL=redis://localhost:6379/0

# --- FastAPI ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:8000

# --- Auth (optional JWT) ---
JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- External APIs ---
OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org/api/v2
OPENFOODFACTS_TIMEOUT=5000

# --- Images ---
IMAGES_DIR=images

# --- Logs ---
# Hourly rotating backend logs. Keep LOG_LEVEL=INFO for normal POS usage.
LOG_DIR=../logs
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=14
LOG_HTTP_ACCESS=true
LOG_HTTP_SKIP_OPTIONS=true
LOG_SLOW_REQUEST_MS=1000

# --- Frontend / tenant selection ---
# Local Docker seed normally creates business/store 1.
# The current shared Neon database may use business/store 6.
VITE_BUSINESS_ID=6
VITE_STORE_ID=6
# Recommended default: leave frontend API/images relative and let Vite proxy them.
# This avoids hardcoded localhost when the app is opened from another machine.
VITE_API_BASE_URL=/api/v1
VITE_IMAGE_BASE_URL=
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
