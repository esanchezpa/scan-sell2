# ============================================================
# VentaFácil — .env.example
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- PostgreSQL ---
# For Neon, use the pooled host (-pooler) in DATABASE_URL and the direct host in DIRECT_DATABASE_URL.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/ventafacil_dev
DIRECT_DATABASE_URL=
DB_ECHO=false

# --- Redis (optional) ---
REDIS_URL=redis://localhost:6379/0

# --- FastAPI ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# --- CORS ---
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:8000

# --- Auth (optional JWT) ---
JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- External APIs ---
OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org/api/v2
OPENFOODFACTS_TIMEOUT=5000

# --- Images ---
IMAGES_DIR=images

# --- Logs ---
# Hourly rotating backend logs. Keep LOG_LEVEL=INFO for normal POS usage.
LOG_DIR=../logs
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=14
LOG_HTTP_ACCESS=true
LOG_HTTP_SKIP_OPTIONS=true
LOG_SLOW_REQUEST_MS=1000
